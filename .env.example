# ===========================================
# Syren AI Influencer Generator - Environment
# ===========================================
# Copy this file to .env and fill in the values

# -----------------------------
# Database Configuration
# -----------------------------
POSTGRES_USER=syren
POSTGRES_PASSWORD=syren_secret_change_me
POSTGRES_DB=syren_db

# -----------------------------
# Redis Configuration
# -----------------------------
# Redis is used for Celery task queue and caching
REDIS_URL=redis://redis:6379/0

# -----------------------------
# Backend Configuration
# -----------------------------
SECRET_KEY=your-super-secret-key-change-in-production
DEBUG=true

# CCBill webhook verification token (passed as ?token=...)
WEBHOOK_SECRET=MY_SECRET

# -----------------------------
# AI Services API Keys
# -----------------------------
# OpenAI API Key for text generation
OPENAI_API_KEY=sk-your-openai-api-key

# Replicate API Token for image/video generation
REPLICATE_API_TOKEN=r8_your-replicate-token

# -----------------------------
# RunPod Configuration
# -----------------------------
# RunPod API Key for serverless endpoints
RUNPOD_API_KEY=your-runpod-api-key

# RunPod Serverless Endpoint ID (from your deployed endpoint)
RUNPOD_ENDPOINT_ID=your-endpoint-id

# Timeout for RunPod jobs (in seconds)
RUNPOD_TIMEOUT_SECONDS=300

# Polling interval (in seconds)
RUNPOD_POLL_INTERVAL=2.0

# -----------------------------
# Frontend Configuration
# -----------------------------
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:8000
